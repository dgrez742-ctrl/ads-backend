# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Retell AI - supports multiple accounts for rotation
RETELL_API_KEY_1=your_retell_api_key_1
RETELL_API_KEY_2=your_retell_api_key_2
RETELL_API_KEY_3=your_retell_api_key_3

# Retell Agent IDs - one agent per Retell account
RETELL_AGENT_ID_1=your_retell_agent_id_1
RETELL_AGENT_ID_2=your_retell_agent_id_2
RETELL_AGENT_ID_3=your_retell_agent_id_3

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# App
PORT=3000
WEBHOOK_SECRET=your_webhook_secret
